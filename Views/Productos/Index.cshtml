@model IEnumerable<VeterinariaWeb.Models.Producto>

@{
    ViewData["Title"] = "Catálogo de Productos";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">📑 Catálogo de Productos</h2>
    <a asp-action="Create" class="btn btn-success">➕ Agregar Producto</a>
</div>

<!-- Filtros -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form class="row g-3">
            <div class="col-md-4">
                <label for="categoria" class="form-label fw-bold">🐾 Categoría</label>
                <select class="form-select" name="categoria" asp-items="ViewBag.categorias">
                    <option value="">--TODOS--</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="producto" class="form-label fw-bold">🔍 Producto</label>
                <input class="form-control" type="text" name="producto" value="@ViewBag.busquedaActual" placeholder="Buscar producto..." />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">🔍 Buscar</button>
            </div>
        </form>
    </div>
</div>

<!-- Tarjetas -->
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-header bg-light fw-bold text-center">
                    @item.Categoria?.Nombre
                </div>
                <img src="@Url.Content("~/" + item.Imagen)" class="card-img-top" alt="@item.Nombre">
                <div class="card-body text-center">
                    <h5 class="card-title fw-bold">@item.Nombre</h5>
                    <p class="text-muted">@item.Descripcion</p>
                    <h6 class="fw-bold text-success">S/. @item.Precio</h6>
                    <div class="mt-3 d-flex gap-2 justify-content-center">
                        <a asp-action="Detail" asp-route-id="@item.ID" class="btn btn-info">👁️ Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-warning">✏️ Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger">🗑️ Eliminar</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Paginación -->
<nav aria-label="Page Navigation">
    <ul class="pagination justify-content-center mt-4">
        <li class="page-item @(ViewBag.paginaActual == 1 ? "disabled" : "")">
            <a class="page-link text-secondary" asp-route-page="@(ViewBag.paginaActual - 1)" asp-route-categoria="@ViewBag.categoriaActual">⬅️ Anterior</a>
        </li>
        @for (int i = 0; i < ViewBag.paginas; i++)
        {
            <li class="page-item @(ViewBag.paginaActual == (i + 1) ? "active" : "")">
                <a class="page-link fw-bold" asp-route-page="@(i + 1)" asp-route-categoria="@ViewBag.categoriaActual">@(i + 1)</a>
            </li>
        }
        <li class="page-item @(ViewBag.paginaActual == ViewBag.paginas ? "disabled" : "")">
            <a class="page-link text-secondary" asp-route-page="@(ViewBag.paginaActual + 1)" asp-route-categoria="@ViewBag.categoriaActual">Siguiente ➡️</a>
        </li>
    </ul>
</nav>
