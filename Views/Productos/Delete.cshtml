@model VeterinariaWeb.Models.Producto

@{
    ViewData["Title"] = "Delete";
}

<h1>Eliminar Producto</h1>

<h4>¿Está seguro que desea eliminar este producto?</h4>
<hr />
<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>

    <dt class="col-sm-2">Descripción</dt>
    <dd class="col-sm-10">@Model.Descripcion</dd>

    <dt class="col-sm-2">Precio</dt>
    <dd class="col-sm-10">S/. @Model.Precio</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="ID" />
    <input type="submit" value="Eliminar" class="btn btn-danger" /> |
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
