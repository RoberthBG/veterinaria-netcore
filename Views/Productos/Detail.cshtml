@model VeterinariaWeb.Models.Producto

@{
    ViewData["Title"] = "Detalle del Producto";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">📦 Detalle del Producto</h2>

    <div class="row">
        <!-- Imagen grande -->
        <div class="col-md-5 text-center">
            <img src="@Url.Content("~/" + Model.Imagen)" alt="@Model.Nombre"
                 class="img-fluid rounded shadow-sm mb-3" style="max-height: 400px;" />
        </div>

        <!-- Datos en tabla mejorada -->
        <div class="col-md-7">
            <table class="table table-bordered table-striped table-hover shadow-sm">
                <thead class="table-primary">
                    <tr>
                        <th>Campo</th>
                        <th>Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><i class="bi bi-hash"></i> ID</td>
                        <td>@Model.ID</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-tag"></i> Nombre</td>
                        <td>@Model.Nombre</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-card-text"></i> Descripción</td>
                        <td>@Model.Descripcion</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-cash-stack"></i> Precio</td>
                        <td class="fw-bold text-success">S/. @Model.Precio</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-box-seam"></i> Categoría</td>
                        <td>@Model.Categoria?.Nombre</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-check-circle"></i> Activo</td>
                        <td>@(Model.Activo ? "Sí" : "No")</td>
                    </tr>
                </tbody>
            </table>

            <!-- Botones de acción -->
            <div class="mt-3 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-warning">✏️ Editar</a>
                <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger">🗑️ Eliminar</a>
                <a asp-action="Index" class="btn btn-secondary">⬅️ Volver al catálogo</a>
            </div>
        </div>
    </div>
</div>
